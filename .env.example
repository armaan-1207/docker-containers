# ===================================================
# AEGIS — Root-level secrets for docker-compose.yml
# Copy to .env in this same directory. NEVER commit .env.
# This is separate from backend/.env (which the backend/celery
# containers read via env_file:) -- this one is read by Compose
# ITSELF for ${...} substitution in docker-compose.yml.
#
# IMPORTANT: AEGIS_DB_PASSWORD here and the password embedded in
# backend/.env's DATABASE_URL must match -- they're the same
# credential, just consumed by two different processes (Postgres'
# own init script here, and SQLAlchemy's connection string there).
# ===================================================

POSTGRES_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD_32CHARS_MIN
AEGIS_DB_PASSWORD=CHANGE_THIS_APP_DB_PASSWORD_32CHARS_MIN
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_32CHARS_MIN