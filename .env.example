# ===================================================
# AEGIS — Root-level secrets for docker-compose.yml
# Copy to .env in this SAME directory (project-docker-containers/).
# NEVER commit .env to version control.
#
# This file is read by Docker Compose for ${...} variable substitution.
# It is SEPARATE from backend/.env (which the backend/celery containers
# read via env_file:).
#
# IMPORTANT: AEGIS_DB_PASSWORD here must match the password embedded in
# backend/.env's DATABASE_URL — they are the same credential consumed by
# two different processes (Postgres init script vs. SQLAlchemy connection).
#
# IMPORTANT: REDIS_PASSWORD here must match REDIS_PASSWORD in backend/.env
# — same credential, used by Redis server startup and by all Redis clients.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ===================================================

# PostgreSQL superuser password (for postgres image internal use)
POSTGRES_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD_32CHARS_MIN

# Application database user password (shared with backend/.env DATABASE_URL)
AEGIS_DB_PASSWORD=CHANGE_THIS_APP_DB_PASSWORD_32CHARS_MIN

# Redis AUTH password (shared with backend/.env REDIS_PASSWORD)
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_32CHARS_MIN

# Logging level for sandbox container
LOG_LEVEL=INFO