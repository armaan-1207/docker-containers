# ===================================================
# AEGIS Backend — Environment Variables Template
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ===================================================

# --- Application ---
APP_NAME=AEGIS Backend
DEBUG=false

# --- Authentication ---
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- PostgreSQL ---
DATABASE_URL=postgresql+psycopg2://aegis_user:aegis_pass@postgres:5432/aegis_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery (defaults to REDIS_URL if blank) ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Shared Volume (matches docker-compose volume mount) ---
SHARED_DIR=/shared/scans

SANDBOX_IMAGE=aegis-sandbox:latest
SHARED_SCANS_VOLUME=shared_scans
SANDBOX_TIMEOUT_SEC=120

# --- Threat Intelligence API Keys ---
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=
OPENPHISH_API_KEY=

# --- Alerting ---
SLACK_WEBHOOK_URL=

# --- ML Model ---
LIGHTGBM_MODEL_PATH=models/lightgbm.pkl

# --- Risk Thresholds ---
SAFE_THRESHOLD=20
LOW_THRESHOLD=40
MEDIUM_THRESHOLD=60
HIGH_THRESHOLD=80

# --- Database Pool ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false