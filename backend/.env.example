# ===================================================
# AEGIS Backend — Environment Variables Template
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ===================================================

# --- Application ---
APP_NAME=AEGIS Backend
DEBUG=false
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS (finding #16) ---
# Comma-separated list of origins allowed to call the API.
# MUST include your Chrome extension origin: chrome-extension://<extension-id>
# For local dev: http://localhost:3000,https://localhost:3000
# For production: chrome-extension://your-extension-id-here,https://dashboard.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# --- PostgreSQL ---
POSTGRES_ROOT_PASSWORD=CHANGE_THIS_POSTGRES_ROOT_PASSWORD
AEGIS_DB_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN
DATABASE_URL=postgresql+psycopg2://aegis_user:CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN@postgres:5432/aegis_db

# --- Redis ---
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
REDIS_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN
REDIS_SECURITY_PASSWORD=CHANGE_THIS_REDIS_SECURITY_PASSWORD_32CHARS_MIN
# REDIS_URL: the password is injected automatically by config.py if REDIS_PASSWORD is set.
# You can also write it explicitly: redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0
REDIS_URL=redis://redis:6379/0
REDIS_SECURITY_URL=redis://redis_security:6379/0

# --- Celery (defaults to REDIS_URL if blank) ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Shared Volume (matches docker-compose volume mount) ---
SHARED_DIR=/shared/scans

# --- Sandbox ---
SANDBOX_NETWORK=dockercontainers_sandbox_net
SANDBOX_IMAGE=aegis-sandbox:v1.0.0@sha256:45b23deeeec969acba3ef1ba0f7ee7cd8312e75e921ebad966d58dc787943cc9
SANDBOX_RUNNER_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN
SHARED_SCANS_VOLUME=dockercontainers_shared_scans
SANDBOX_TIMEOUT_SEC=120

# --- Artifact Retention (finding #8) ---
# How many days to keep per-scan artifacts on disk before the hourly
# file_cleanup task purges them. Adjust based on your disk capacity.
ARTIFACT_RETENTION_DAYS=14

# --- Threat Intelligence API Keys ---
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=
OPENPHISH_API_KEY=

# --- Alerting ---
SLACK_WEBHOOK_URL=

# --- ML Model ---
LIGHTGBM_MODEL_PATH=models/lightgbm.pkl

# --- Risk Thresholds ---
SAFE_THRESHOLD=20
LOW_THRESHOLD=40
MEDIUM_THRESHOLD=60
HIGH_THRESHOLD=80

# --- Database Pool ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Logging ---
LOG_LEVEL=INFO